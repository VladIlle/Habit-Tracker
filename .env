# =====================================================
# HabitFlow - Variabile de Mediu
# Copiază în .env și completează cu valorile tale!
# NICIODATĂ nu comite .env în git!
# =====================================================

# Parola bazei de date PostgreSQL
DB_PASSWORD=schimba_aceasta_parola_db_123!

# Secret JWT (minim 32 caractere aleatorii)
# Generează cu: openssl rand -hex 32
JWT_SECRET=schimba_acest_secret_jwt_cu_ceva_foarte_lung_si_aleatoriu_456

# Cheie criptare AES-256 (EXACT 64 caractere hex = 32 bytes)
# Generează cu: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Parola implicită pentru contul admin (va fi schimbată la prima logare)
# Username admin: admin
ADMIN_PASSWORD=Admin@HabitFlow2024!
